# Poort waarop de companion draait (serveert API + WebSocket + PWA)
PORT=4317

# Bind-adres. 127.0.0.1 = alleen deze machine (default, veilig).
# Zet op 0.0.0.0 om het paneel op je LAN / via Tailscale te bereiken.
HOST=127.0.0.1

# Verplicht token zodra HOST niet 127.0.0.1/localhost is.
# Leeg laten bij puur localhost-gebruik.
AUTH_TOKEN=

# Pad naar de VS Code CLI (voor 'open VS Code'). Standaard 'code' op PATH.
CODE_BIN=code
